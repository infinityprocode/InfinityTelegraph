# Copy to .env.local (gitignored).

# Telegraph miner dispatcher (testnet live node).
TELEGRAPH_DISPATCHER_URL=http://13.237.89.59:7044/miner-dispatcher

# Our miner id once registered on Base Sepolia (numeric). Blank until registered.
INFINITY_MINER_ID=

# For local dev before Telegraph integration: hit our miner API directly.
# In production this call goes through the dispatcher + x402 payment instead.
MINER_DIRECT_URL=http://127.0.0.1:8080

# Burner wallet key for x402 payments (Base Sepolia). NEVER a real wallet. Server-side only.
X402_PRIVATE_KEY=
