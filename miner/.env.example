# Copy to .env (gitignored). NEVER commit real values.

# API key the Telegraph node injects as X-API-Key when routing to us.
# Leave blank for local dev (auth is skipped when unset).
INFINITY_MINER_API_KEY=

# Fee address (EVM, Base Sepolia) where MACHINA payouts go. Burner wallet only.
FEE_ADDRESS=

# Optional: market data source for the real model (set when the model lands).
MARKET_DATA_URL=
